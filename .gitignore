# =============================================================================
# Hexplain — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so

# --- Virtual environments ---
.venv/
venv/
env/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Environment & secrets (NEVER commit) ---
.env
.env.local
.env.production
jwt_secret.txt
csrf_secret.txt
*.secret
*.key

# --- Runtime databases (auto-generated) ---
*.db
*.sqlite3
backend/data/

# --- ChromaDB vector store (auto-generated) ---
backend/data/chromadb/

# --- Quarantine volume (NEVER commit uploaded malware samples) ---
backend/quarantine/
quarantine/

# --- Node.js ---
node_modules/
.next/
frontend/.next/
frontend/out/
frontend/build/

# --- Docker ---
docker-compose.override.yml

# --- OS ---
.DS_Store
Thumbs.db

# --- Testing artifacts ---
.pytest_cache/
.coverage
htmlcov/
cookies.txt

# --- Alembic compiled ---
migrations/versions/*.pyc

# --- Logs ---
*.log

# --- Audit and temp files ---
audit_artifacts/
*.tmp
*.bak
