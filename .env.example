# =============================================================================
# MalwAIre — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Security ---
# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, an ephemeral key is generated (sessions won't survive restarts).
JWT_SECRET_KEY=

# CSRF signing key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SECRET_KEY=

# Set to "true" in production (HTTPS). Enables Secure flag on cookies.
SECURE_COOKIES=false

# --- Database ---
# SQLite (default for development)
DATABASE_URL=sqlite:///./data/malwaire.db

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://redis:6379/0

# --- File Upload ---
# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=25

# Quarantine directory (absolute path inside container)
QUARANTINE_DIR=/app/quarantine

# Data directory (for SQLite DB)
DATA_DIR=/app/data

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- JWT ---
# Token expiry in minutes
JWT_EXPIRY_MINUTES=30

# --- Rate Limiting ---
# Format: "count/period" (e.g., "5/minute")
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute

# --- Threat Intel (Sprint 2) ---
# VirusTotal API key (free tier: 4 req/min, 500/day)
# Get one at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# MalwareBazaar API key (free, required for hash lookups)
# Get one at: https://auth.abuse.ch/
MALWAREBAZAAR_API_KEY=

# --- Analysis Settings (Sprint 2) ---
GHIDRA_INSTALL_DIR=/opt/ghidra
GHIDRA_TIMEOUT_SECONDS=120
GHIDRA_MAX_FUNCTIONS=10
YARA_RULES_DIR=/app/yara-rules
CAPA_RULES_DIR=/app/capa-rules
