# =============================================================================
# Hexplain — Environment Configuration Template
# Copy this file to .env and fill in the required values.
# Never commit .env or any file containing real secrets to version control.
# =============================================================================

# --- Security (REQUIRED) ---
# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Without this, an ephemeral key is generated on startup (sessions lost on restart).
JWT_SECRET_KEY=

# CSRF signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SECRET_KEY=

# Set to "true" in production (HTTPS only). Enables the Secure flag on all cookies.
SECURE_COOKIES=false

# --- Database ---
# SQLite (default for development). For production, consider migrating to PostgreSQL.
DATABASE_URL=sqlite:///./data/hexplain.db

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://redis:6379/0

# --- File Upload ---
# Maximum allowed upload size in megabytes
MAX_UPLOAD_SIZE_MB=25

# Quarantine directory (absolute path inside container — do not change unless you edit docker-compose.yml)
QUARANTINE_DIR=/app/quarantine

# Data directory (SQLite database and ChromaDB embeddings)
DATA_DIR=/app/data

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- JWT ---
# Access token expiry in minutes (default: 30 minutes)
JWT_EXPIRY_MINUTES=30

# --- Rate Limiting ---
# Format: "count/period" (e.g., "5/minute", "100/hour")
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
UPLOAD_RATE_LIMIT=10/minute

# =============================================================================
# THREAT INTELLIGENCE APIS (all free tiers available)
# =============================================================================

# VirusTotal — free tier: 4 requests/min, 500/day
# Register at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# MalwareBazaar (abuse.ch) — free, no rate limits for hash lookups
# Register at: https://auth.abuse.ch/
MALWAREBAZAAR_API_KEY=

# AlienVault OTX — free, no strict rate limits
# Register at: https://otx.alienvault.com/
OTX_API_KEY=

# =============================================================================
# LLM PROVIDERS (only one is required — the system falls back automatically)
# =============================================================================

# --- Primary LLM: Google Gemini ---
# Recommended: Gemini 2.0 Flash (free tier available)
# Register at: https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Secondary LLM: Groq (fallback) ---
# Fast inference for open-source models (llama-3.1-8b-instant, free tier)
# Register at: https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# If neither key is set, the LLM layer is skipped.
# The static analysis pipeline still runs and produces a heuristic report.

# =============================================================================
# ANALYSIS TOOLS (paths inside the Docker container — adjust only if you change Dockerfile)
# =============================================================================

# Ghidra headless installation directory
GHIDRA_INSTALL_DIR=/opt/ghidra

# Analysis timeouts and limits
GHIDRA_TIMEOUT_SECONDS=120
GHIDRA_MAX_FUNCTIONS=10

# YARA rules directory (community rules are bundled in the image)
YARA_RULES_DIR=/app/yara-rules

# Capa rules directory (Mandiant rules are bundled in the image)
CAPA_RULES_DIR=/app/capa-rules

# =============================================================================
# RAG CONFIGURATION
# =============================================================================

# Sentence-transformer model for embedding (runs locally, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of context chunks retrieved per RAG query
RAG_TOP_K=5

# =============================================================================
# DEPLOYMENT (production only)
# =============================================================================

# Set to "production" to disable debug routes and enable stricter logging
ENVIRONMENT=development

# Application host and port (used by uvicorn inside the container)
APP_HOST=0.0.0.0
APP_PORT=8000
